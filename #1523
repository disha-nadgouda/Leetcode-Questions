class Solution {
   
    public int countOdds(int low, int high) {
        int count=0;
        System.out.println("Enter Low:");
        System.out.println("Enter High:");
        for(int i=low;i<=high;i++){
            
            if(i%2!=0){
                count++;
            }
        }
        return count;
        
    }
}
